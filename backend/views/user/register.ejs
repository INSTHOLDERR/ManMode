<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/images/logo.ico"><title>Register — ManMode</title>
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>(function(){const t=localStorage.getItem('mmTheme')||'light';document.documentElement.setAttribute('data-theme',t);})()</script>
</head>
<body>
<div class="mm-auth-page">
  <div class="mm-auth-left">
    <img src="/images/registration.jpg" class="mm-auth-img" alt="ManMode">
    <div class="mm-auth-left-text">
      <h2 class="mm-auth-left-title">Join the ManMode Community</h2>
      <p class="mm-auth-left-sub">Create your account with email verification to get started.</p>
    </div>
  </div>

  <div class="mm-auth-right">
    <div class="mm-auth-card">
      <a href="/" class="mm-auth-logo">ManMode</a>

      <!-- Step 1: Fill details -->
      <div id="step1">
        <h1 class="mm-auth-title">Create Account</h1>
        <p class="mm-auth-sub">Join thousands of well-dressed men</p>
        <div class="mm-auth-form" id="regForm">
          <div class="mm-form-group">
            <label class="mm-label">Full Name</label>
            <input type="text" class="mm-input" id="regName" placeholder="Your full name" required>
            <p id="nameMsg" style="font-size:.72rem;min-height:.875rem;margin-top:.25rem;"></p>
          </div>
          <div class="mm-form-group">
            <label class="mm-label">Email Address</label>
            <input type="email" class="mm-input" id="regEmail" placeholder="you@example.com" required>
            <p id="emailMsg" style="font-size:.72rem;min-height:.875rem;margin-top:.25rem;"></p>
          </div>
          <div class="mm-form-group">
            <label class="mm-label">Password</label>
            <div class="mm-input-wrap">
              <input type="password" class="mm-input" id="regPwd" placeholder="Min. 6 characters" required>
              <button type="button" class="mm-eye-btn" onclick="togglePwd('regPwd',this)"><i class="fas fa-eye"></i></button>
            </div>
            <p id="pwdMsg" style="font-size:.72rem;min-height:.875rem;margin-top:.25rem;"></p>
          </div>
          <div class="mm-form-group">
            <label class="mm-label">Confirm Password</label>
            <div class="mm-input-wrap">
              <input type="password" class="mm-input" id="regPwd2" placeholder="Repeat password" required>
              <button type="button" class="mm-eye-btn" onclick="togglePwd('regPwd2',this)"><i class="fas fa-eye"></i></button>
            </div>
          </div>
          <button class="mm-btn mm-btn-primary mm-auth-submit" id="step1Btn" onclick="sendRegOtp()">
            Send OTP <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      </div>

      <!-- Step 2: OTP -->
      <div id="step2" style="display:none;">
        <h1 class="mm-auth-title">Verify Email</h1>
        <p class="mm-auth-sub">OTP sent to <strong id="regDisplayEmail" style="color:var(--gold);"></strong></p>
        <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r-md);padding:1rem;margin-bottom:1.25rem;text-align:center;">
          <input type="text" class="mm-input" id="regOtpInput"
            placeholder="• • • • • •" maxlength="6"
            style="font-size:2rem;letter-spacing:.5em;text-align:center;font-weight:900;border:none;background:transparent;padding:.5rem;width:100%;outline:none;color:var(--gold);">
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <span id="regTimer" style="font-size:.875rem;color:var(--gold);font-weight:600;"><i class="fas fa-clock"></i> 05:00</span>
          <button id="regResendBtn" onclick="sendRegOtp(true)" style="display:none;font-size:.8125rem;font-weight:700;color:var(--gold);background:none;border:none;cursor:pointer;">
            <i class="fas fa-redo"></i> Resend
          </button>
        </div>
        <button class="mm-btn mm-btn-primary mm-auth-submit" id="step2Btn" onclick="verifyRegOtp()">
          <i class="fas fa-check-circle"></i> Verify & Register
        </button>
        <button class="mm-btn mm-btn-ghost" style="width:100%;justify-content:center;margin-top:.75rem;" onclick="backToStep1()">
          ← Back
        </button>
      </div>

      <div class="mm-divider">or</div>
      <a href="/auth/google" class="mm-google-btn">
        <svg viewBox="0 0 24 24" width="20" height="20"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Sign up with Google
      </a>
      <p class="mm-auth-switch">Already have an account? <a href="/login">Sign in →</a></p>
    </div>
  </div>
</div>

<script>
function togglePwd(id,btn){const f=document.getElementById(id);const s=f.type==='password';f.type=s?'text':'password';btn.innerHTML=s?'<i class="fas fa-eye-slash"></i>':'<i class="fas fa-eye"></i>';}
function swal(opts){return Swal.fire({confirmButtonColor:'#b8860b',...opts});}

function setMsg(id,text,ok){const el=document.getElementById(id);if(!el)return;el.textContent=text;el.style.color=ok?'var(--green)':'var(--red)';}
document.getElementById('regName').oninput  = function(){setMsg('nameMsg', this.value.length>=6?'✓ Valid':'Min. 6 characters', this.value.length>=6);}
document.getElementById('regEmail').oninput = function(){const ok=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.value);setMsg('emailMsg',ok?'✓ Valid email':'Enter valid email',ok);}
document.getElementById('regPwd').oninput   = function(){setMsg('pwdMsg',this.value.length>=6?'✓ Strong':'Min. 6 characters',this.value.length>=6);}

let regTimer;
function startRegTimer(){
  let left=300;
  const el=document.getElementById('regTimer'),re=document.getElementById('regResendBtn');
  re.style.display='none';clearInterval(regTimer);
  regTimer=setInterval(()=>{left--;const m=String(Math.floor(left/60)).padStart(2,'0'),s=String(left%60).padStart(2,'0');el.innerHTML=`<i class="fas fa-clock"></i> ${m}:${s}`;if(left<=0){clearInterval(regTimer);el.innerHTML='<span style="color:var(--red)">Expired</span>';re.style.display='block';}},1000);
}

async function sendRegOtp(isResend) {
  const name  = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pwd   = document.getElementById('regPwd').value;
  const pwd2  = document.getElementById('regPwd2').value;

  if (!isResend) {
    if (!name||!email||!pwd||!pwd2)    return swal({title:'Fill all fields',icon:'warning'});
    if (name.length<6)                  return swal({title:'Name too short',text:'Min. 6 characters',icon:'warning'});
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return swal({title:'Invalid email',icon:'warning'});
    if (pwd.length<6)                   return swal({title:'Password too short',text:'Min. 6 characters',icon:'warning'});
    if (pwd!==pwd2)                     return swal({title:'Passwords do not match',icon:'warning'});
  }

  const btn = document.getElementById('step1Btn');
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Sending OTP…'; btn.disabled=true;

  try {
    const res  = await fetch('/send-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email})});
    const data = await res.json();
    if (!res.ok) throw new Error(data.message||data.error||'Failed');
    document.getElementById('regDisplayEmail').textContent = email;
    document.getElementById('step1').style.display='none';
    document.getElementById('step2').style.display='block';
    document.getElementById('regOtpInput').value='';
    document.getElementById('regOtpInput').focus();
    startRegTimer();
  } catch(e) {
    swal({title:'Error',text:e.message,icon:'error'});
    btn.innerHTML='Send OTP <i class="fas fa-paper-plane"></i>'; btn.disabled=false;
  }
}

function backToStep1(){
  clearInterval(regTimer);
  document.getElementById('step1').style.display='block';
  document.getElementById('step2').style.display='none';
  const btn=document.getElementById('step1Btn');
  btn.innerHTML='Send OTP <i class="fas fa-paper-plane"></i>'; btn.disabled=false;
}

async function verifyRegOtp(){
  const email = document.getElementById('regEmail').value.trim();
  const otp   = document.getElementById('regOtpInput').value.trim();
  if (!otp||otp.length<6) return swal({title:'Enter 6-digit OTP',icon:'warning'});

  const btn = document.getElementById('step2Btn');
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Verifying…'; btn.disabled=true;

  try {
    // Validate OTP
    const vRes = await fetch('/validate-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,otp})});
    const vData= await vRes.json();
    if (!vRes.ok) throw new Error(vData.error||'Wrong OTP');

    // Register
    const name = document.getElementById('regName').value.trim();
    const pwd  = document.getElementById('regPwd').value;
    const rRes = await fetch('/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,email,password:pwd,confirmPassword:pwd})});
    const rData= await rRes.json();
    if (!rRes.ok) throw new Error(rData.error||rData.message||'Registration failed');

    clearInterval(regTimer);
    await swal({title:'Account Created! 🎉',text:'You can now sign in.',icon:'success',timer:1800,showConfirmButton:false});
    window.location.href='/login';
  } catch(e){
    swal({title:'Error',text:e.message,icon:'error'});
    btn.innerHTML='<i class="fas fa-check-circle"></i> Verify & Register'; btn.disabled=false;
  }
}

document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('regOtpInput').addEventListener('keypress',e=>{if(e.key==='Enter')verifyRegOtp();});
});
</script>
</body>
</html>
