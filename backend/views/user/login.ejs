<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/images/logo.ico"><title>Login — ManMode</title>
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>(function(){const t=localStorage.getItem('mmTheme')||'light';document.documentElement.setAttribute('data-theme',t);})()</script>
</head>
<body>
<div class="mm-auth-page">
  <!-- Left panel -->
  <div class="mm-auth-left">
    <img src="/images/registration.jpg" class="mm-auth-img" alt="ManMode">
    <div class="mm-auth-left-text">
      <h2 class="mm-auth-left-title">Dress Like a Gentleman</h2>
      <p class="mm-auth-left-sub">Premium men's fashion for the modern man. Secure login with OTP verification.</p>
    </div>
  </div>

  <!-- Right panel -->
  <div class="mm-auth-right">
    <div class="mm-auth-card">
      <a href="/" class="mm-auth-logo">ManMode</a>

      <!-- Step 1: Email + Password -->
      <div id="step1">
        <h1 class="mm-auth-title">Welcome back</h1>
        <p class="mm-auth-sub">Sign in to your account</p>
        <div class="mm-auth-form">
          <div class="mm-form-group">
            <label class="mm-label">Email Address</label>
            <input type="email" class="mm-input" id="loginEmail" placeholder="you@example.com" required autocomplete="email">
          </div>
          <div class="mm-form-group">
            <label class="mm-label">Password</label>
            <div class="mm-input-wrap">
              <input type="password" class="mm-input" id="loginPwd" placeholder="Your password" required autocomplete="current-password">
              <button type="button" class="mm-eye-btn" onclick="togglePwd('loginPwd',this)"><i class="fas fa-eye"></i></button>
            </div>
          </div>
          <a href="/forgot-password-email" class="mm-forgot-link">Forgot Password?</a>
          <button class="mm-btn mm-btn-primary mm-auth-submit" id="sendOtpBtn" onclick="sendLoginOtp()">
            Continue <i class="fas fa-arrow-right"></i>
          </button>
        </div>
      </div>

      <!-- Step 2: OTP Verification -->
      <div id="step2" style="display:none;">
        <h1 class="mm-auth-title">Verify It's You</h1>
        <p class="mm-auth-sub">Enter the OTP sent to <strong id="displayEmail" style="color:var(--gold);"></strong></p>

        <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r-md);padding:1rem;margin-bottom:1.25rem;text-align:center;">
          <input type="text" class="mm-input" id="otpInput"
            placeholder="• • • • • •"
            maxlength="6"
            style="font-size:2rem;letter-spacing:.5em;text-align:center;font-weight:900;border:none;background:transparent;padding:.5rem;width:100%;outline:none;color:var(--gold);">
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <span id="timerDisplay" style="font-size:.875rem;color:var(--gold);font-weight:600;"><i class="fas fa-clock"></i> 05:00</span>
          <button id="resendOtpBtn" onclick="resendOtp()" style="display:none;font-size:.8125rem;font-weight:700;color:var(--gold);background:none;border:none;cursor:pointer;padding:0;">
            <i class="fas fa-redo"></i> Resend OTP
          </button>
        </div>

        <button class="mm-btn mm-btn-primary mm-auth-submit" id="verifyBtn" onclick="verifyLoginOtp()">
          <i class="fas fa-shield-alt"></i> Verify & Login
        </button>
        <button class="mm-btn mm-btn-ghost" style="width:100%;justify-content:center;margin-top:.75rem;" onclick="goBack()">
          ← Back
        </button>
      </div>

      <div class="mm-divider">or</div>
      <a href="/auth/google" class="mm-google-btn">
        <svg viewBox="0 0 24 24" width="20" height="20"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Sign in with Google
      </a>
      <p class="mm-auth-switch">Don't have an account? <a href="/register">Create one →</a></p>
    </div>
  </div>
</div>

<script>
function togglePwd(id,btn){const f=document.getElementById(id);const s=f.type==='password';f.type=s?'text':'password';btn.innerHTML=s?'<i class="fas fa-eye-slash"></i>':'<i class="fas fa-eye"></i>';}

function swal(opts){ return Swal.fire({ confirmButtonColor:'#b8860b', ...opts }); }

let timerInterval;
function startTimer() {
  let left = 300;
  const el = document.getElementById('timerDisplay');
  const re = document.getElementById('resendOtpBtn');
  re.style.display = 'none';
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    left--;
    const m = String(Math.floor(left/60)).padStart(2,'0');
    const s = String(left%60).padStart(2,'0');
    el.innerHTML = `<i class="fas fa-clock"></i> ${m}:${s}`;
    if (left <= 0) {
      clearInterval(timerInterval);
      el.innerHTML = '<span style="color:var(--red)">OTP expired</span>';
      re.style.display = 'block';
    }
  }, 1000);
}

async function sendLoginOtp() {
  const email = document.getElementById('loginEmail').value.trim();
  const pwd   = document.getElementById('loginPwd').value;
  if (!email || !pwd) return swal({ title:'Fill all fields', icon:'warning' });

  const btn = document.getElementById('sendOtpBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending OTP…'; btn.disabled = true;

  try {
    const res  = await fetch('/send-login-otp', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email,password:pwd}) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || 'Failed to send OTP');

    document.getElementById('displayEmail').textContent = email;
    document.getElementById('step1').style.display = 'none';
    document.getElementById('step2').style.display = 'block';
    document.getElementById('otpInput').value = '';
    document.getElementById('otpInput').focus();
    startTimer();
  } catch(e) {
    swal({ title:'Error', text: e.message, icon:'error' });
    btn.innerHTML = 'Continue <i class="fas fa-arrow-right"></i>'; btn.disabled = false;
  }
}

function goBack() {
  clearInterval(timerInterval);
  document.getElementById('step1').style.display = 'block';
  document.getElementById('step2').style.display = 'none';
  const btn = document.getElementById('sendOtpBtn');
  btn.innerHTML = 'Continue <i class="fas fa-arrow-right"></i>'; btn.disabled = false;
}

async function resendOtp() {
  document.getElementById('resendOtpBtn').style.display = 'none';
  await sendLoginOtp();
}

async function verifyLoginOtp() {
  const email = document.getElementById('loginEmail').value.trim();
  const otp   = document.getElementById('otpInput').value.trim();
  if (!otp || otp.length < 6) return swal({ title:'Enter 6-digit OTP', icon:'warning' });

  const btn = document.getElementById('verifyBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Verifying…'; btn.disabled = true;

  try {
    const res  = await fetch('/login', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email,otp}) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || 'Verification failed');
    clearInterval(timerInterval);
    window.location.href = '/userhome';
  } catch(e) {
    swal({ title:'Error', text: e.message, icon:'error' });
    btn.innerHTML = '<i class="fas fa-shield-alt"></i> Verify & Login'; btn.disabled = false;
  }
}

// Allow Enter key on OTP input
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('otpInput').addEventListener('keypress', e => {
    if (e.key === 'Enter') verifyLoginOtp();
  });
  document.getElementById('loginPwd').addEventListener('keypress', e => {
    if (e.key === 'Enter') sendLoginOtp();
  });
});
</script>
</body>
</html>
