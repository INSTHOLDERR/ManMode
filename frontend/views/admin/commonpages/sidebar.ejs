<script>
// Mark active link by matching current URL path
(function() {
  const path = window.location.pathname;
  document.querySelectorAll('.adm-nav-link[data-page]').forEach(link => {
    const page = link.getAttribute('data-page');
    if (path.includes(page)) {
      link.classList.add('active');
    }
  });
})();

// Mobile sidebar toggle
const admHamBtn  = document.getElementById('admHamBtn');
const admSidebar = document.getElementById('admSidebar');
const admOverlay = document.getElementById('admOverlay');
if (admHamBtn) {
  admHamBtn.addEventListener('click', () => {
    admSidebar.classList.toggle('open');
    admOverlay.classList.toggle('open');
  });
}
if (admOverlay) {
  admOverlay.addEventListener('click', () => {
    admSidebar.classList.remove('open');
    admOverlay.classList.remove('open');
  });
}
</script>
