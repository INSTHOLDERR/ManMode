<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/images/logo.ico"><title>Forgot Password — ManMode</title>
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>(function(){const t=localStorage.getItem('mmTheme')||'light';document.documentElement.setAttribute('data-theme',t);})()</script>
</head>
<body>
<div class="mm-auth-page">
  <div class="mm-auth-left">
    <img src="/images/forgotpass.jpg" class="mm-auth-img" alt="Forgot Password">
    <div class="mm-auth-left-text">
      <h2 class="mm-auth-left-title">Reset Your Password</h2>
      <p class="mm-auth-left-sub">Enter your email and we'll send you an OTP to reset your password securely.</p>
    </div>
  </div>
  <div class="mm-auth-right">
    <div class="mm-auth-card">
      <a href="/login" class="mm-auth-logo">ManMode</a>
      <h1 class="mm-auth-title">Forgot Password?</h1>
      <p class="mm-auth-sub">No worries — we'll send you reset instructions</p>

      <!-- Step 1: Email -->
      <div id="step1">
        <div class="mm-form-group" style="margin-bottom:1.25rem;">
          <label class="mm-label">Email Address</label>
          <input type="email" class="mm-input" id="fpEmail" placeholder="you@example.com" required autocomplete="email">
        </div>
        <button class="mm-btn mm-btn-primary" id="sendOtpBtn" style="width:100%;padding:1rem;font-size:.9375rem;justify-content:center;">
          <i class="fas fa-paper-plane"></i> Send OTP
        </button>
      </div>

      <!-- Step 2: OTP verification -->
      <div id="step2" style="display:none;">
        <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r-md);padding:1rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.625rem;">
          <i class="fas fa-envelope" style="color:var(--gold);"></i>
          <p style="font-size:.875rem;color:var(--ink-2);">OTP sent to <strong id="displayEmail"></strong></p>
        </div>
        <div class="mm-form-group" style="margin-bottom:.5rem;">
          <label class="mm-label">Enter OTP</label>
          <input type="text" class="mm-input" id="otpInput" placeholder="6-digit code" maxlength="6" style="font-size:1.5rem;letter-spacing:.25em;text-align:center;font-weight:700;">
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <span id="timerText" style="font-size:.8125rem;color:var(--gold);font-weight:600;">⏱ 05:00</span>
          <button id="resendBtn" style="display:none;font-size:.8125rem;color:var(--gold);font-weight:700;background:none;border:none;cursor:pointer;">Resend OTP</button>
        </div>
        <button class="mm-btn mm-btn-primary" id="verifyOtpBtn" style="width:100%;padding:1rem;justify-content:center;">
          <i class="fas fa-check-circle"></i> Verify OTP
        </button>
        <button class="mm-btn mm-btn-ghost" id="backBtn" style="width:100%;padding:.75rem;justify-content:center;margin-top:.75rem;">
          ← Change Email
        </button>
      </div>

      <!-- Step 3: New password -->
      <div id="step3" style="display:none;">
        <div style="background:var(--green-pale,#f0fdf4);border:1px solid #bbf7d0;border-radius:var(--r-md);padding:1rem;margin-bottom:1.25rem;">
          <p style="font-size:.875rem;color:#15803d;font-weight:600;"><i class="fas fa-check-circle" style="margin-right:.375rem;"></i>Email verified! Set your new password.</p>
        </div>
        <div class="mm-form-group" style="margin-bottom:1rem;">
          <label class="mm-label">New Password</label>
          <div class="mm-input-wrap">
            <input type="password" class="mm-input" id="newPwd" placeholder="Min. 6 characters">
            <button type="button" class="mm-eye-btn" onclick="togglePwd('newPwd',this)"><i class="fas fa-eye"></i></button>
          </div>
        </div>
        <div class="mm-form-group" style="margin-bottom:1.25rem;">
          <label class="mm-label">Confirm Password</label>
          <div class="mm-input-wrap">
            <input type="password" class="mm-input" id="confirmPwd" placeholder="Repeat new password">
            <button type="button" class="mm-eye-btn" onclick="togglePwd('confirmPwd',this)"><i class="fas fa-eye"></i></button>
          </div>
        </div>
        <button class="mm-btn mm-btn-primary" id="resetPwdBtn" style="width:100%;padding:1rem;justify-content:center;">
          <i class="fas fa-lock"></i> Reset Password
        </button>
      </div>

      <p class="mm-auth-switch">Remembered it? <a href="/login">Back to Login</a></p>
    </div>
  </div>
</div>

<script>
function togglePwd(id,btn){const f=document.getElementById(id);const s=f.type==='password';f.type=s?'text':'password';btn.innerHTML=s?'<i class="fas fa-eye-slash"></i>':'<i class="fas fa-eye"></i>';}

function swal2(opts){ return Swal.fire({confirmButtonColor:'var(--gold)', background: document.documentElement.getAttribute('data-theme')==='dark'?'#1a1a1a':'#fff', color: document.documentElement.getAttribute('data-theme')==='dark'?'#f0f0f0':'#111', ...opts }); }

let timerInterval;
function startTimer(seconds) {
  let left = seconds;
  const timerEl  = document.getElementById('timerText');
  const resendBtn = document.getElementById('resendBtn');
  resendBtn.style.display = 'none';
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    left--;
    const m = String(Math.floor(left/60)).padStart(2,'0');
    const s = String(left%60).padStart(2,'0');
    timerEl.textContent = `⏱ ${m}:${s}`;
    if (left <= 0) {
      clearInterval(timerInterval);
      timerEl.textContent = 'OTP expired';
      resendBtn.style.display = 'block';
    }
  }, 1000);
}

const email = () => document.getElementById('fpEmail').value.trim();

async function sendOtp(isResend) {
  const btn = document.getElementById(isResend ? 'resendBtn' : 'sendOtpBtn');
  if (!email()) return swal2({ title:'Enter your email', icon:'warning' });
  btn.disabled = true;
  btn.innerHTML = isResend ? 'Sending…' : '<i class="fas fa-spinner fa-spin"></i> Sending OTP…';
  try {
    const res  = await fetch('/forgot-send-otp', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ email: email() }) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || 'Failed to send OTP');
    document.getElementById('displayEmail').textContent = email();
    document.getElementById('step1').style.display = 'none';
    document.getElementById('step2').style.display = 'block';
    document.getElementById('otpInput').value = '';
    startTimer(300);
  } catch(e) {
    swal2({ title:'Error', text: e.message, icon:'error' });
    btn.disabled = false;
    btn.innerHTML = isResend ? 'Resend OTP' : '<i class="fas fa-paper-plane"></i> Send OTP';
  }
}

document.getElementById('sendOtpBtn').onclick  = () => sendOtp(false);
document.getElementById('resendBtn').onclick   = () => sendOtp(true);
document.getElementById('backBtn').onclick     = () => {
  clearInterval(timerInterval);
  document.getElementById('step1').style.display = 'block';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('sendOtpBtn').disabled = false;
  document.getElementById('sendOtpBtn').innerHTML = '<i class="fas fa-paper-plane"></i> Send OTP';
};

document.getElementById('verifyOtpBtn').onclick = async () => {
  const otp = document.getElementById('otpInput').value.trim();
  if (!otp || otp.length < 6) return swal2({ title:'Enter 6-digit OTP', icon:'warning' });
  document.getElementById('verifyOtpBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Verifying…';
  document.getElementById('verifyOtpBtn').disabled = true;
  try {
    const res  = await fetch('/validate-otp', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ email: email(), otp }) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Wrong OTP');
    clearInterval(timerInterval);
    document.getElementById('step2').style.display = 'none';
    document.getElementById('step3').style.display = 'block';
  } catch(e) {
    swal2({ title:'Wrong OTP', text: e.message, icon:'error' });
    document.getElementById('verifyOtpBtn').innerHTML = '<i class="fas fa-check-circle"></i> Verify OTP';
    document.getElementById('verifyOtpBtn').disabled = false;
  }
};

document.getElementById('resetPwdBtn').onclick = async () => {
  const pwd  = document.getElementById('newPwd').value;
  const cpwd = document.getElementById('confirmPwd').value;
  if (!pwd || pwd.length < 6) return swal2({ title:'Password too short', text:'Min. 6 characters', icon:'warning' });
  if (pwd !== cpwd) return swal2({ title:'Passwords do not match', icon:'warning' });
  document.getElementById('resetPwdBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Resetting…';
  document.getElementById('resetPwdBtn').disabled = true;
  try {
    const res  = await fetch('/update-password', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ password: pwd, confirmPassword: cpwd }) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Reset failed');
    await swal2({ title:'Password Reset! ✅', text:'You can now log in with your new password.', icon:'success', timer:2000, showConfirmButton:false });
    window.location.href = '/login';
  } catch(e) {
    swal2({ title:'Error', text: e.message, icon:'error' });
    document.getElementById('resetPwdBtn').innerHTML = '<i class="fas fa-lock"></i> Reset Password';
    document.getElementById('resetPwdBtn').disabled = false;
  }
};
</script>
</body>
</html>
